# Copy this file to .env in the same directory and fill in real values.
# Never commit .env to git.

# MongoDB connection (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/snhu_foodwaste
# Legacy alias still supported by config/db.js
MONGO_URI=mongodb://127.0.0.1:27017/snhu_foodwaste

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# API port (frontend is served from the same server in development)
PORT=5002

# Optional: set to "test" when running Jest
# NODE_ENV=test
